# FastAPI 服务配置
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
SERVICE_DEBUG=true

# 飞书开放平台配置
# 应用凭证，在飞书开放平台创建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 企业租户key，自建应用可不填，ISV应用需要填写
FEISHU_TENANT_KEY=
# 飞书API地址，国内默认即可，海外需要替换为对应区域地址
FEISHU_API_BASE_URL=https://open.feishu.cn

# LLM 配置
# 支持所有兼容OpenAI协议的大模型服务
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL_NAME=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# 业务配置
# 飞书任务默认归属项目ID，创建任务时会归属到该项目下
FEISHU_TASK_PROJECT_ID=
# 飞书消息卡片模板ID，可选，不填则使用默认卡片
FEISHU_NOTIFICATION_TEMPLATE_ID=
